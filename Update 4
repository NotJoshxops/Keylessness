-- THEME ENGINE
local function ApplyTheme(themeName)
    local data = Themes[themeName] or Themes["Dark Glass"]
    local isLight = (data.bg.R + data.bg.G + data.bg.B) > 1.5
    local subCol = isLight and Color3.fromRGB(100, 100, 110) or Color3.fromRGB(180, 180, 190)
    
    Tween(MainFrame, {BackgroundColor3 = data.bg, BackgroundTransparency = data.alpha})
    Tween(Header, {BackgroundColor3 = data.top, BackgroundTransparency = data.alpha})
    Tween(StatLabel, {TextColor3 = data.text})
    Tween(Mini, {BackgroundColor3 = data.text, TextColor3 = data.bg})
    Tween(DisplayName, {TextColor3 = data.text})
    Tween(DCBtn, {TextColor3 = subCol})
    Tween(TabIndicator, {BackgroundColor3 = data.text})
    Tween(SearchFrame, {BackgroundColor3 = data.btn, BackgroundTransparency = data.alpha + 0.2})
    Tween(SearchBox, {TextColor3 = data.text, PlaceholderColor3 = subCol})
    Tween(Branding, {TextColor3 = data.text})
    Tween(CreditsLabel, {TextColor3 = data.text})
    
    SearchStroke.Color = data.accent; MainStroke.Color = data.accent
    
    for _, v in pairs(MainFrame:GetDescendants()) do
        if v:IsA("TextButton") and v.Name == "ScriptBtn" then
            Tween(v, {BackgroundColor3 = data.btn, BackgroundTransparency = data.alpha + 0.15})
            if v:FindFirstChild("T1") then Tween(v.T1, {TextColor3 = data.text}) end
            if v:FindFirstChild("T2") then Tween(v.T2, {TextColor3 = subCol}) end
            if v:FindFirstChild("WidgetStroke") then v.WidgetStroke.Color = data.accent end
        elseif v:IsA("TextButton") and v.Parent == TabFrame then 
            Tween(v, {TextColor3 = subCol}) 
        end
    end
    UserSettings.SelectedTheme = themeName; SaveSettings(UserSettings)
end

