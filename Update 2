-- THEME APPLIER
local function ApplyTheme(themeName)
    local data = Themes[themeName] or Themes["Normal"]
    local isLight = (data.bg.R + data.bg.G + data.bg.B) > 1.5
    local textCol = isLight and Color3.fromRGB(40, 40, 50) or Color3.fromRGB(255, 255, 255)
    local subCol = isLight and Color3.fromRGB(80, 80, 100) or Color3.fromRGB(160, 160, 160)

    Tween(MainFrame, {BackgroundColor3 = data.bg})
    Tween(Header, {BackgroundColor3 = data.top})
    Tween(TabFrame, {BackgroundColor3 = data.top})
    Tween(StatLabel, {TextColor3 = data.accent})
    Tween(Mini, {BackgroundColor3 = data.accent})
    Tween(DisplayName, {TextColor3 = textCol})
    Tween(DCBtn, {TextColor3 = subCol})
    Tween(TabIndicator, {BackgroundColor3 = data.accent})
    MainStroke.Color = data.accent
    
    for _, v in pairs(MainFrame:GetDescendants()) do
        if v:IsA("TextButton") and v.Name == "ScriptBtn" then
            Tween(v, {BackgroundColor3 = data.btn})
            if v:FindFirstChild("T1") then Tween(v.T1, {TextColor3 = textCol}) end
            if v:FindFirstChild("T2") then Tween(v.T2, {TextColor3 = subCol}) end
        elseif v:IsA("TextButton") and v.Parent == TabFrame then
            Tween(v, {TextColor3 = subCol})
        end
    end
    UserSettings.SelectedTheme = themeName; SaveSettings(UserSettings)
end

