local SaveFile = "KeylessnessThemes.json"
local DefaultSettings = {SelectedTheme = "Dark Glass"}

local function SaveSettings(tbl)
    pcall(function() writefile(SaveFile, HttpService:JSONEncode(tbl)) end)
end

local function LoadSettings()
    local s, res = pcall(function() return readfile(SaveFile) end)
    if s then 
        local decoded = HttpService:JSONDecode(res)
        if decoded.SelectedTheme == "iOS Liquid" or decoded.SelectedTheme == "Midnight Glass" then 
            decoded.SelectedTheme = "Dark Glass" 
        end
        return decoded 
    end
    return DefaultSettings
end

