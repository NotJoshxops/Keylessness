local function CreateScroll(name)
    local s = Instance.new("ScrollingFrame")
    s.Name = name
    s.Size = UDim2.new(1, 0, 1, -85)
    s.Position = UDim2.new(0, 0, 0, 80)
    s.BackgroundTransparency = 1
    s.BorderSizePixel = 0
    s.CanvasSize = UDim2.new(0, 0, 0, 600)
    s.ScrollBarThickness = 2
    s.Visible = false
    s.Parent = MainFrame
    Instance.new("UIListLayout", s).HorizontalAlignment = Enum.HorizontalAlignment.Center
    s.UIListLayout.Padding = UDim.new(0, 8)
    return s
end

