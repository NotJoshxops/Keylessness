local function CreateBtn(parent, name, sub, func)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 220, 0, 46)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
    btn.Text = ""
    btn.Parent = parent
    Instance.new("UICorner", btn)

    local t1 = Instance.new("TextLabel")
    t1.Size = UDim2.new(1, 0, 0.6, 0)
    t1.BackgroundTransparency = 1
    t1.Text = name
    t1.TextColor3 = Color3.fromRGB(255, 255, 255); t1.Font = Enum.Font.GothamBold
    t1.TextSize = 10; t1.Parent = btn

    local t2 = Instance.new("TextLabel")
    t2.Size = UDim2.new(1, 0, 0.4, 0); t2.Position = UDim2.new(0, 0, 0.5, 0)
    t2.BackgroundTransparency = 1; t2.Text = sub
    t2.TextColor3 = Color3.fromRGB(150, 150, 150); t2.TextSize = 8; t2.Parent = btn

    btn.MouseButton1Click:Connect(function() func() Notify(name) end)
end

